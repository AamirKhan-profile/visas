<!DOCTYPE html>
<html>
<head>
    <title>All Visas</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f0f2f5;
            margin: 0;
            padding: 20px;
        }

        h1 {
            text-align: center;
            margin-bottom: 30px;
            color: #2c3e50;
        }

        .users-container {
            display: flex;
            flex-direction: column;
            gap: 20px;
            max-width: 900px;
            margin: 0 auto;
        }

        .user-card {
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 6px 15px rgba(0,0,0,0.1);
            padding: 20px;
        }

        .user-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }

        .user-header h2 {
            margin: 0;
            font-size: 22px;
            color: #34495e;
        }

        .delete-btn {
            background-color: #e74c3c;
            color: white;
            border: none;
            padding: 8px 15px;
            border-radius: 5px;
            cursor: pointer;
            font-size: 14px;
        }

        .delete-btn:hover {
            background-color: #c0392b;
        }

        .user-info p {
            margin: 5px 0;
        }

        .user-images {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 10px;
        }

        .user-images img {
            max-width: 150px;
            height: auto;
            border-radius: 8px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }
    </style>
</head>
<body>
    <h1>All Users  <span><a href="/" style="color:red; margin-left:20px">Back to Site</a></span></h1>

    <% if (users && users.length > 0) { %>
        <div class="users-container">
            <% users.forEach(function(user) { %>
                <div class="user-card">
                    <div class="user-header">
                        <h2><%= user.name %></h2>
                        <form action="/users/delete/<%= user._id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this user?');">
                            <button type="submit" class="delete-btn">Delete</button>
                        </form>
                    </div>
                    <div class="user-info">
                        <p><strong>Passport Number:</strong> <%= user.passportNumber %></p>
                        <p><strong>Document Number:</strong> <%= user.documentNumber %></p>
                        <p><strong>Country:</strong> <%= user.country %></p>
                    </div>
                    <% if (user.images && user.images.length > 0) { %>
                        <div class="user-images">
                            <% user.images.forEach(function(img) { %>
                                <img src="<%= img %>" alt="User Document">
                            <% }); %>
                        </div>
                    <% } %>
                </div>
            <% }); %>
        </div>
    <% } else { %>
        <p style="text-align:center; font-size:18px; color:#7f8c8d;">No users available.</p>
    <% } %>
</body>
</html>
