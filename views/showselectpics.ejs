<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Selected Pictures</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <style>
        body {
            font-family: Arial, sans-serif;
            background: #f2f4f7;
            padding: 20px;
        }
        .wrapper {
            max-width: 1200px;
            margin: auto;
        }
        .record {
            background: #fff;
            padding: 15px;
            margin-bottom: 25px;
            border-radius: 8px;
            box-shadow: 0 2px 6px rgba(0,0,0,0.08);
        }
        .name {
            font-size: 18px;
            font-weight: bold;
            margin-bottom: 15px;
            text-transform: uppercase;
        }
        .pics {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
            gap: 15px;
        }
        .pic-box {
            border: 1px solid #ddd;
            border-radius: 6px;
            padding: 10px;
            background: #fafafa;
            text-align: center;
        }
        .pic-box img {
            width: 100%;
            height: 150px;
            object-fit: cover;
            border-radius: 4px;
        }
        .delete-btn {
            margin-top: 8px;
            background: #e53935;
            color: #fff;
            border: none;
            padding: 6px 12px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 14px;
        }
    </style>
</head>
<body>

<div class="wrapper">

    <% pictures.forEach(item => { %>
        <div class="record">
            <div class="name"><%= item.applicantName %></div>

            <div class="pics">
                <% item.pictures.forEach((pic, index) => { %>
                    <div class="pic-box">
                        <img src="/<%= pic %>" alt="Picture">

                        <!-- DELETE SINGLE IMAGE -->
                        <form
                            action="/pictures/delete-one/<%= item._id %>"
                            method="POST"
                            onsubmit="return confirm('Delete this picture?')"
                        >
                            <button class="delete-btn" type="submit">
                                Delete
                            </button>
                        </form>
                    </div>
                <% }) %>
            </div>
        </div>
    <% }) %>

</div>

</body>
</html>