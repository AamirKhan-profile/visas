<!-- ══════════ SCRIPTS ══════════ -->
<script>
  /* ── Background canvas — soft green/red orbs ── */
  (function(){
    const c = document.getElementById('bg-canvas');
    const ctx = c.getContext('2d');
    let W, H;
    const orbs = [];

    function resize(){ W = c.width = innerWidth; H = c.height = innerHeight; }
    resize(); window.addEventListener('resize', resize);

    const colors = ['rgba(26,107,58,', 'rgba(46,173,94,', 'rgba(192,57,43,', 'rgba(231,76,60,'];
    for(let i=0;i<18;i++){
      orbs.push({
        x: Math.random()*W, y: Math.random()*H,
        r: Math.random()*180+60,
        vx: (Math.random()-.5)*.25, vy: (Math.random()-.5)*.25,
        color: colors[Math.floor(Math.random()*colors.length)],
        a: Math.random()*.09+.03
      });
    }

    function draw(){
      ctx.clearRect(0,0,W,H);
      orbs.forEach(o=>{
        o.x+=o.vx; o.y+=o.vy;
        if(o.x<-o.r) o.x=W+o.r; if(o.x>W+o.r) o.x=-o.r;
        if(o.y<-o.r) o.y=H+o.r; if(o.y>H+o.r) o.y=-o.r;
        const g = ctx.createRadialGradient(o.x,o.y,0,o.x,o.y,o.r);
        g.addColorStop(0, o.color+o.a+')');
        g.addColorStop(1, o.color+'0)');
        ctx.beginPath(); ctx.arc(o.x,o.y,o.r,0,Math.PI*2);
        ctx.fillStyle=g; ctx.fill();
      });
      requestAnimationFrame(draw);
    }
    draw();
  })();

  /* ── Counter animation ── */
  function animCount(el){
    const target = +el.dataset.count;
    let v = 0;
    const step = Math.ceil(target/55);
    const id = setInterval(()=>{
      v = Math.min(v+step, target);
      el.textContent = v;
      if(v>=target) clearInterval(id);
    }, 28);
  }
  const obs = new IntersectionObserver(entries=>{
    entries.forEach(e=>{ if(e.isIntersecting){ animCount(e.target); obs.unobserve(e.target); } });
  },{threshold:.6});
  document.querySelectorAll('.stat-num').forEach(n=>obs.observe(n));

  /* ── Card scroll reveal ── */
  const cardObs = new IntersectionObserver(entries=>{
    entries.forEach(e=>{
      if(e.isIntersecting){
        const d = (+e.target.dataset.delay||0)*160;
        setTimeout(()=>e.target.classList.add('visible'), d);
        cardObs.unobserve(e.target);
      }
    });
  },{threshold:.12});
  document.querySelectorAll('.card').forEach(c=>cardObs.observe(c));
</script>
